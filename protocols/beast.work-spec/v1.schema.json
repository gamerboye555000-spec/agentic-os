{"$defs":{"AosTaskId":{"description":"The AOS ledger's human-facing task id, e.g. T-0001. Never a runtime UUID.","maxLength":21,"minLength":3,"pattern":"^T-[0-9]{1,19}$","type":"string"},"BoundedError":{"additionalProperties":false,"properties":{"code":{"maxLength":64,"minLength":3,"pattern":"^[a-z][a-z0-9_]{2,63}$","type":"string"},"message":{"maxLength":512,"minLength":1,"type":"string"},"retryable":{"type":"boolean"}},"required":["code","message","retryable"],"type":"object"},"EvidenceRef":{"additionalProperties":false,"properties":{"claim":{"maxLength":1024,"minLength":1,"type":"string"},"kind":{"description":"IS models.EVIDENCE_KINDS (D-v0.3.10).","enum":["note","file","commit","test","url","command_output"],"type":"string"},"provenance":{"maxLength":70,"minLength":5,"pattern":"^(human|agent:[A-Za-z0-9._-]{1,63})$","type":"string"},"ref":{"maxLength":1024,"minLength":1,"type":"string"},"sha256":{"$ref":"#/$defs/Sha256"}},"required":["kind","ref","claim","provenance"],"type":"object"},"Issuer":{"maxLength":64,"minLength":3,"pattern":"^[a-z][a-z0-9._-]{2,63}$","type":"string"},"OpaqueRef":{"description":"An opaque versioned reference to a record owned by another system. Never dereferenced here.","maxLength":132,"minLength":3,"pattern":"^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}/v[1-9][0-9]{0,3}$","type":"string"},"Scope":{"additionalProperties":false,"properties":{"project":{"description":"An AOS project slug (a bounded narrowing of models.SLUG_RE).","maxLength":64,"minLength":1,"pattern":"^[a-z0-9][a-z0-9._-]{0,63}$","type":"string"},"tenant":{"maxLength":64,"minLength":1,"pattern":"^[a-z0-9][a-z0-9._-]{0,63}$","type":"string"}},"required":["project"],"type":"object"},"Sha256":{"maxLength":64,"minLength":64,"pattern":"^[0-9a-f]{64}$","type":"string"},"Timestamp":{"description":"UTC RFC3339, second precision, literal Z.","maxLength":20,"minLength":20,"pattern":"^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$","type":"string"},"Trace":{"additionalProperties":fals