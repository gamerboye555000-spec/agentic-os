"schema","protocol_version","content_hash_alg","content_sha256","created_at","issuer","audience","scope","trace","idempotency_key","aos_task_id","data_classification","permitted_destinations","work_spec_id","goal","acceptance_criteria","expected_result"],"title":"WorkSpec v1","type":"object"}
